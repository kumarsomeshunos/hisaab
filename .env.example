# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is git-ignored.

# Neon PostgreSQL connection string (from your Neon project dashboard)
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# Resend API key (from resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key

# Sender address — must be a verified domain in Resend
FROM_EMAIL=hisaab.kumarsomesh.com

# Canonical URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 — media attachments for expenses
# Account ID from your Cloudflare dashboard (Workers & Pages > R2)
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
# R2 API token with Object Read & Write permissions
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
# Name of the R2 bucket you created
CLOUDFLARE_R2_BUCKET=dutch-media
# Public bucket URL (e.g. https://pub-xxxx.r2.dev) — enable public access in R2 settings
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev
