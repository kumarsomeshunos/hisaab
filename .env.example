# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is git-ignored.

# Neon PostgreSQL connection string (from your Neon project dashboard)
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# Resend API key (from resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key

# Sender address — must be a verified domain in Resend
FROM_EMAIL=hisaab.kumarsomesh.com

# Canonical URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
